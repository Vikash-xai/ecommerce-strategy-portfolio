# Google OAuth (Google Cloud Console -> APIs & Services -> Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Random secret used by Auth.js to encrypt sessions. Generate with:
#   npx auth secret
AUTH_SECRET=

# GitHub fine-grained personal access token, scoped to this repo only,
# with "Contents: Read and write" permission. Used by the /admin/biodata
# editor to commit changes to app/biodata/biodataData.ts.
GITHUB_TOKEN=
